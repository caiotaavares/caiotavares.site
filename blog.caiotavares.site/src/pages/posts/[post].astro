---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";

interface Frontmatter {
    title: string;
    date?: string;
    description?: string;
}

interface Post {
    file: string;
    frontmatter: Frontmatter;
    Content: any;
}

export async function getStaticPaths() {
    const posts = Object.values(
        import.meta.glob<Post>("../../blog/*.md", { eager: true }),
    );

    return posts.map((post) => {
        const slug = post.file.split("/").pop()?.replace(".md", "") || "";
        return {
            params: { post: slug },
            props: { post },
        };
    });
}

const { post } = Astro.props as { post: Post };
const { Content } = post;
const { title } = post.frontmatter;
---

<Layout>
    <div class="container">
        {/* Importamos apenas o Header reutilizável */}
        <Header />

        <article class="post-container">
            <!-- <h1>{title}</h1> -->
            <div class="content">
                <Content />
            </div>
        </article>
    </div>
</Layout>

<style>
    :root {
        --fontColor: #141414;
        --redBGColor: #ff2c2c;
    }

    .post-container {
        color: var(--fontColor);
    }

    .post-container :global(h1) {
        margin-top: 1.5em;
        font-size: 50px;
        padding-bottom: 1em;
        color: var(--fontColor);
        font-weight: bold;
    }

    .content {
        color: var(--fontColor);
        line-height: 1.6;
        font-size: 22px;
        font-weight: 300;
        text-align: justify;
        text-justify: inter-word;
    }
</style>
