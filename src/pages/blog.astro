---
import Layout from '../layouts/LayoutBlog.astro';

// Use Astro.glob to fetch all markdown files in the posts directory.
const posts = await Astro.glob('./posts/*.md');
// Sort by date descending (optional)
posts.sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Layout title="Blog - Caio Tavares">
    <div class="centered-text red-text">
        <div class="about-me" id="blog-container">
            <h1>Blog</h1>
            
            {posts.length === 0 ? (
                <p>Nenhum post encontrado.</p>
            ) : (
                posts.map(post => (
                    <div class="blog-post-item">
                        <h2><a href={post.url}>{post.frontmatter.title}</a></h2>
                        <p class="date"><i class="fa-regular fa-calendar"></i> {post.frontmatter.date}</p>
                        {post.frontmatter.tags && (
                            <div class="tag-container">
                                {post.frontmatter.tags.map(tag => (
                                    <span class="tag">{tag}</span>
                                ))}
                            </div>
                        )}

                    </div>
                ))
            )}
        </div>
    </div>
</Layout>
