---
import '../styles/style.css';

const { title = "Caio Tavares" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
</head>
<body>
    <!-- Header -->
    <header>
        <div class="nav-container">
            <nav class="nav-links">
                <a href="/">Home</a>
                <a href="/blog">Blog</a>
            </nav>
        </div>
        <div class="profile">
            <img src="/img/fiodor-dostoievski.jpg" alt="" width="150px"><br>
            <h1><span>Caio Tavares</span></h1>
        </div>
        
    </header>

    <slot />

    <!-- Footer -->
    <div class="footer">
        <p>&copy; Copyright 2024 <br>Maked with <i class="fa-solid fa-mug-hot"></i> By Caio Tavares</p>
    </div>

    <!-- FontAwesome -->
    <script src="https://kit.fontawesome.com/aa5f332820.js" crossorigin="anonymous"></script>
</body>
</html>
