---
import '../styles/global.css';
import '../styles/style.css';
import LanguagePicker from '../components/LanguagePicker.astro';

const { title = "Caio Tavares", alternate } = Astro.props;
const lang = Astro.currentLocale || 'pt';

const t = {
    pt: { home: "Início", blog: "Blog", copyright: "Feito com", by: "Por" },
    en: { home: "Home", blog: "Blog", copyright: "Made with", by: "By" }
}[lang];

const isEn = lang === 'en';
const currentUrl = new URL(Astro.url.pathname, Astro.site || 'https://caiotavares.site');

let alternateUrl;
if (alternate) {
    alternateUrl = new URL(alternate, Astro.site || 'https://caiotavares.site');
} else {
    // Basic automatic mapping
    if (isEn) {
        alternateUrl = new URL(Astro.url.pathname.replace(/^\/en/, '') || '/', Astro.site || 'https://caiotavares.site');
    } else {
        alternateUrl = new URL(`/en${Astro.url.pathname === '/' ? '' : Astro.url.pathname}`, Astro.site || 'https://caiotavares.site');
    }
}
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>

    <!-- SEO: Hreflang -->
    <link rel="alternate" hreflang={isEn ? 'pt' : 'en'} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={isEn ? alternateUrl : currentUrl} />
</head>
<body>
    <!-- Header -->
    <header>
        <div class="nav-container">
            <nav class="nav-links">
                <a href={isEn ? "/en" : "/"}>{t.home}</a>
                <a href={isEn ? "/en/blog" : "/blog"}>{t.blog}</a>
                <LanguagePicker />
            </nav>
        </div>
        <div class="profile">
            <img src="/img/fiodor-dostoievski.jpg" alt="" width="150px"><br>
            <h1><span>Caio Tavares</span></h1>
        </div>
        
    </header>

    <slot />

    <!-- Footer -->
    <div class="footer">
        <p>&copy; Copyright 2024 <br>{t.copyright} <i class="fa-solid fa-mug-hot"></i> {t.by} Caio Tavares</p>
    </div>

    <!-- FontAwesome -->
    <script src="https://kit.fontawesome.com/aa5f332820.js" crossorigin="anonymous"></script>
</body>
</html>

